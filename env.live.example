TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Required for live Polymarket trading
POLYMARKET_PRIVATE_KEY=

# Usually the wallet/profile address that actually holds funds on Polymarket.
# For EOAs this is often your wallet address.
# For email / proxy / Magic-style setups use the funded proxy wallet.
POLYMARKET_FUNDER=
POLYMARKET_PROFILE_ADDRESS=

# 0 for normal wallet signatures, 1 for Magic/email/proxy-style signatures
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_CHAIN_ID=137
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# Optional but recommended to persist in .env after first derive
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASS_PHRASE=
